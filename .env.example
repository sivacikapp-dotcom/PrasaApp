# ─── Firebase client (public — NEXT_PUBLIC prefix is intentional) ────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key (public)
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── Firebase Admin SDK (server-side only — NEVER use NEXT_PUBLIC prefix) ────
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON content as a single line (escape newlines)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Mapbox (public — for Vizuálna trasa map) ────────────────────────────────
# mapbox.com → Account → Access tokens → Create token (restrict to your domain!)
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── OpenAI (server-side only) ────────────────────────────────────────────────
# platform.openai.com → API keys → Create new secret key
OPENAI_API_KEY=

# ─── Resend (server-side only — email notifications) ─────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=
# The "from" address — must be from a verified domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Optional: override all outgoing emails to this address (useful on Resend free tier)
RESEND_TEST_EMAIL=

# ─── Upstash Redis (server-side only — rate limiting) ────────────────────────
# console.upstash.com → Create database → REST API → copy URL and token
# Leave empty to disable rate limiting (allowed in development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
